<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=web" />
    <link rel="stylesheet" href="/styles/variables.css">
    <link rel="stylesheet" href="/styles/base.css" data-pagedjs-ignore>
    <link rel="stylesheet" href="/styles/config.css" data-pagedjs-ignore>
    <link rel="stylesheet" href="/styles/sidebar.css" data-pagedjs-ignore>
    <link rel="stylesheet" href="/styles/print.css" data-pagedjs-ignore>

    {% block head %}{% endblock %}

    <title> Exploring Creative Technologies</title>
</head>

<body>

    <div id="mainContainer">


        {# {% for moc in collections.moc %}
        <script>
            window.sidebarContent.push("{{moc.url}}");
            console.log(window.sidebarContent)
        </script>

        {% endfor %} #}
        {# {{page.url}} #}

        <aside id="sidebar">
            <script>
                if (localStorage.getItem('sidebarCollapsed') === 'true') {
                    document.getElementById('sidebar').classList.add('collapsed');
                }
            </script>
            {% include "partials/navbar.njk" %}
        </aside>

        <template id="templateSource">

            {{ content | injectTags(tags) | linkClass | addHeadingIds | safe }}
        </template>

        <template id="templateContent">
            {{ content | injectTags(tags) | linkClass | addHeadingIds | safe }}
        </template>

        <div id="midContainer">
            <article id="content">
            </article>

        </div>

        <aside id="config">
            <script>
                if (localStorage.getItem('configCollapsed') === 'true') {
                    document.getElementById('config').classList.add('collapsed');
                }
            </script>
            {% include "partials/config.njk" %}
        </aside>

    </div>


    <script type="module">
        import { setView } from "/js/switchView.js";
        setView();

        document.querySelectorAll('.moc-sidebar-container:not(#sidebar-default) > h1').forEach(h1 => {
            h1.addEventListener('click', () => {
                switchMoc(''); 
            });
            h1.style.cursor = "pointer";
        });

        function toggleSidebar() {
            const activeMocUrl = localStorage.sidebarContent;

            // 1. Verstecke alle Sidebar-Gruppen
            document.querySelectorAll('.sidebar-group').forEach(group => {
                group.style.display = 'none';
            });

            // Highlight den aktiven MOC-Button
            document.querySelectorAll('button[data-moc-btn-url]').forEach(btn => {
                btn.classList.remove('active-moc');
                if (activeMocUrl && btn.getAttribute('data-moc-btn-url') === activeMocUrl) {
                    btn.classList.add('active-moc');
                }
            });

            const mocControls = document.getElementById('mocControls');

            // 2. Zeige das aktive MOC an, falls gesetzt
            if (activeMocUrl) {
                const activeContainer = document.querySelector(`.sidebar-group[data-moc-url="${activeMocUrl}"]`);
                if (activeContainer) {
                    activeContainer.style.display = 'block';
                    if (mocControls) mocControls.style.display = 'flex';
                    return;
                }
            }

            // 3. Fallback: Zeige die Standard-Sidebar mit allen Posts
            const defaultSidebar = document.getElementById('sidebar-default');
            if (defaultSidebar) {
                defaultSidebar.style.display = 'block';
            }
            if (mocControls) mocControls.style.display = 'none';
        }

        window.switchMoc = function (url) {
            localStorage.sidebarContent = url;
            toggleSidebar();
            highlightCurrentPage();
        };

        function highlightCurrentPage() {
            const currentPath = decodeURI(window.location.pathname);
            const links = document.querySelectorAll('#sidebarContent li a');
            let activeLink = null;

            links.forEach(link => {
                const href = link.getAttribute('href');
                if (!href) {
                    link.classList.remove('active');
                    return;
                }

                try {
                    const linkPath = decodeURI(new URL(link.href).pathname);
                    if (linkPath === currentPath || linkPath === currentPath + '/' || linkPath + '/' === currentPath) {
                        link.classList.add('active');
                        const group = link.closest('.sidebar-group');
                        if (group && group.style.display !== 'none') {
                            activeLink = link;
                        }
                    } else {
                        link.classList.remove('active');
                    }
                } catch (e) {
                    link.classList.remove('active');
                }
            });

            if (activeLink) {
                // setTimeout ensures the display: block has taken effect before calculating scroll
                // setTimeout(() => {
                //     activeLink.scrollIntoView({ behavior: 'smooth', block: 'start' });
                // }, 50);
            }
        }

        toggleSidebar();
        highlightCurrentPage();
        
        window.navigateMoc = function (direction) {
            const activeMocUrl = localStorage.sidebarContent;
            if (!activeMocUrl) return;

            const group = document.querySelector(`.sidebar-group[data-moc-url="${activeMocUrl}"]`);
            if (!group || group.style.display === 'none') return;

            const links = Array.from(group.querySelectorAll('a'));
            if (links.length === 0) return;

            const currentPath = decodeURI(window.location.pathname);
            let currentIndex = links.findIndex(link => {
                const linkPath = decodeURI(new URL(link.href).pathname);
                return linkPath === currentPath || linkPath === currentPath + '/' || linkPath + '/' === currentPath;
            });

            let targetIndex = 0;
            if (currentIndex !== -1) {
                targetIndex = currentIndex + direction;
            } else {
                targetIndex = direction > 0 ? 0 : links.length - 1;
            }

            if (targetIndex >= 0 && targetIndex < links.length) {
                window.location.href = links[targetIndex].href;
            }
        };

        window.addEventListener('keydown', (event) => {
            if (event.target.tagName === 'INPUT' || event.target.tagName === 'TEXTAREA') return;

            if (event.key === 'ArrowUp') {
                event.preventDefault();
                navigateMoc(-1);
            } else if (event.key === 'ArrowDown') {
                event.preventDefault();
                navigateMoc(1);
            }
        });

        // Main sidebar toggling with smooth slide scaling
        const mainSidebar = document.getElementById('sidebar');
        if (mainSidebar) {
            mainSidebar.addEventListener('dblclick', function(e) {
                if(e.target.tagName !== 'BUTTON' && e.target.tagName !== 'A' && !e.target.closest('button') && !e.target.closest('a')) {
                    const isCollapsed = this.classList.toggle('collapsed');
                    localStorage.setItem('sidebarCollapsed', isCollapsed);
                    
                    let start = performance.now();
                    requestAnimationFrame(function step(time) {
                        window.dispatchEvent(new Event('resize'));
                        if (time - start < 150) {
                            requestAnimationFrame(step);
                        }
                    });
                }
            });
        }

        // Config sidebar toggling with smooth slide scaling
        const configSidebar = document.getElementById('config');
        if (configSidebar) {
            configSidebar.addEventListener('dblclick', function(e) {
                if(e.target.tagName !== 'BUTTON' && e.target.tagName !== 'A' && !e.target.closest('button') && !e.target.closest('a')) {
                    const isCollapsed = this.classList.toggle('collapsed');
                    localStorage.setItem('configCollapsed', isCollapsed);
                    
                    // Trigger resize events during CSS transition to scale slides smoothly
                    let start = performance.now();
                    requestAnimationFrame(function step(time) {
                        window.dispatchEvent(new Event('resize'));
                        if (time - start < 150) {
                            requestAnimationFrame(step);
                        }
                    });
                }
            });
        }
    </script>

</body>

</html>