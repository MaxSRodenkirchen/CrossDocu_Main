<div id="ECT">

    <h1>Exploring Creative Technologies</h1>

    <ul class = "allLists">

        <li class = "aList"> Journal

            <ol class = "listContent">

                <p class="listSection">This week</p>

                <li class = "contentLink">
                    Touchdesigner Course
                </li>

                <li class = "contentLink">
                    p5.js Course

                    <ol class = "contentSections">
                        <li>Intro</li>
                        <li>Start Section</li>
                        <li>Keep on reading</li>
                    </ol>
                </li>
            </ol>    
        </li>
        
        <li class = "aList"> Creative Coding

            <ul class = "listContent">

                <li class = "contentLink">Tracking Movement in p5.js
                </li>

                <li class = "contentLink">
                    p5.js Course

                    <ol class = "contentSections">

                        <li>Intro</li>
                        <li>Start Section</li>
                        <li>Keep on reading</li>

                    </ol>

                </li>
            </ul>    
        </li>

        {% for item in collections | sortTagsByCount %}
            {% set tag = item.tag %}
            {% set posts = item.posts %}
            <li class="aList aTagList"> 
                {{ tag | cleanTags }}
                <ul class="listContent">
                    {% for post in posts %}
                        <li class="contentLink">
                            <a href="{{ post.url }}">{{ post.data.title | default(post.fileSlug) }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </li>
        {% endfor %}
    </ul>

</div>