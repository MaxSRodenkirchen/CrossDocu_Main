<div id="sections">

    <h1>Sections</h1>

    {{content | getSections | safe}}

    <div id="slideControls">
        <button class="sectionButton" onclick="prevSlide()" title="Previous Section">
            {% icon "arrow-left" %} Previous Section
        </button>
        <button class="sectionButton" onclick="nextSlide()" title="Next Section">
            {% icon "arrow-right" %} Next Section
        </button>
    </div>
    <button class="sectionButton" onclick="toggleFullscreen()" title="Toggle Fullscreen" >
        {% icon "expand" %} Fullscreen
    </button>

</div>



<div id="viewModeContainer">
    <button id="webButton" class="viewModeButton" onclick="switchView('web')">
        Web Mode
    </button>
    <button class="viewModeButton" onclick="switchView('print')">
        Print Mode
    </button>
    <button class="viewModeButton" onclick="switchView('slide')">
        Slide Mode
    </button>
</div>





